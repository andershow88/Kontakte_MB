<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Kontaktdatenbank – @ViewData["Title"]</title>
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;600;700&family=Roboto:wght@300;400;500;700&display=swap" />
    <link rel="stylesheet" href="~/css/merkur.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/kontakte.css" asp-append-version="true" />
    <!-- Darkmode sofort anwenden, bevor der Body gerendert wird (kein Flackern) -->
    <script>
        (function () {
            var t = localStorage.getItem('mc-theme');
            if (t === 'dark') document.documentElement.setAttribute('data-theme', 'dark');
        })();
    </script>
</head>
<body class="mc-body">

    <!-- Sidebar -->
    <nav class="mc-sidebar" id="sidebar">
        <div class="mc-sidebar-brand">
            <div class="mc-logo">
                <img src="~/images/merkur-logo.svg" alt="Merkur Privatbank KGaA" class="mc-logo-img" />
                <div>
                    <div class="mc-logo-title">Kontaktdatenbank</div>
                    <div class="mc-logo-subtitle">MERKUR PRIVATBANK KGaA</div>
                </div>
            </div>
        </div>

        <div class="mc-sidebar-bank">
            <div class="mc-sidebar-bank-label">Angemeldet als</div>
            <div class="mc-sidebar-bank-name">
                <i class="bi bi-person-circle me-1"></i>@User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value
            </div>
        </div>

        <ul class="mc-nav">
            <li class="mc-nav-item">
                <a class="mc-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
                   asp-controller="Home" asp-action="Index">
                    <i class="bi bi-speedometer2"></i>
                    <span>Kontaktdashboard</span>
                </a>
            </li>
            <li class="mc-nav-item">
                <a class="mc-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Companies" ? "active" : "")"
                   asp-controller="Companies" asp-action="Index">
                    <i class="bi bi-buildings"></i>
                    <span>Firmen</span>
                </a>
            </li>
            <li class="mc-nav-item">
                <a class="mc-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Contacts" ? "active" : "")"
                   asp-controller="Contacts" asp-action="Index">
                    <i class="bi bi-people"></i>
                    <span>Kontakte</span>
                </a>
            </li>
            <li class="mc-nav-item">
                <a class="mc-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Search" ? "active" : "")"
                   asp-controller="Search" asp-action="Index">
                    <i class="bi bi-search"></i>
                    <span>Suche</span>
                </a>
            </li>
        </ul>

        <!-- Abmelden-Button auskommentiert (Auto-Login aktiv)
        <div class="mc-sidebar-footer">
            <form asp-controller="Account" asp-action="Logout" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="mc-logout-btn">
                    <i class="bi bi-box-arrow-left"></i>
                    <span>Abmelden</span>
                </button>
            </form>
        </div>
        -->
    </nav>

    <!-- Main -->
    <div class="mc-main" id="main-content">
        <header class="mc-topbar" style="gap:.75rem;">
            <button class="mc-sidebar-toggle d-lg-none" id="sidebarToggle">
                <i class="bi bi-list"></i>
            </button>

            <!-- ── Globale Suchleiste mit Mode-Toggle ── -->
            <form action="/Search" method="get" id="topbarSearchForm"
                  style="flex:1; display:flex; align-items:center; gap:0;"
                  autocomplete="off">
                <input type="hidden" name="mode" id="topbarMode" value="smart" />
                <button type="button" class="topbar-pick-btn topbar-pick-smart" onclick="topbarSetMode('smart')"
                        title="Suche ohne KI">
                    <i class="bi bi-cpu"></i>
                    <span class="d-none d-md-inline">Suche ohne KI</span>
                </button>
                <button type="button" class="topbar-pick-btn topbar-pick-ai" onclick="topbarSetMode('ai')"
                        title="KI-Suche">
                    <i class="bi bi-stars"></i>
                    <span class="d-none d-md-inline">KI-Suche</span>
                </button>
                <div class="topbar-search-bar" id="topbarSearchBar">
                    <div class="topbar-search-locked" id="topbarLocked">
                        <i class="bi bi-lock"></i>
                        <span>Suchmethode wählen</span>
                    </div>
                    <input id="topbarSearchInput" name="q" type="text"
                           class="topbar-search-input"
                           placeholder=""
                           disabled />
                    <button type="submit" class="topbar-search-submit" id="topbarSubmit" disabled
                            title="Suchen">
                        <i class="bi bi-arrow-right-circle-fill"></i>
                    </button>
                </div>
            </form>

            <div class="mc-topbar-right" style="flex-shrink:0;">
                <span class="mc-topbar-date d-none d-md-inline">
                    <i class="bi bi-calendar3 me-1"></i>@DateTime.Now.ToString("dd.MM.yyyy")
                </span>
                <!-- Darkmode-Toggle -->
                <button class="mc-theme-toggle" id="themeToggle" title="Design wechseln">
                    <i class="bi bi-moon-fill" id="themeIcon"></i>
                </button>
            </div>
        </header>

        <!-- ── KI-Assistent Modal ──────────────────────────────────────── -->
        <div id="aiModal" style="display:none; position:fixed; inset:0; z-index:1000; align-items:flex-start; justify-content:center; padding-top:70px;">
            <div onclick="aiSchliessen()" style="position:absolute; inset:0; background:rgba(0,0,0,0.5); backdrop-filter:blur(3px);"></div>
            <div style="position:relative; width:min(720px,96vw); max-height:calc(100vh - 90px);
                        background:var(--mc-surface); border-radius:16px;
                        box-shadow:0 30px 70px rgba(0,0,0,0.3); display:flex;
                        flex-direction:column; overflow:hidden; border:1px solid var(--mc-border);">

                <div style="padding:.85rem 1.2rem; background:linear-gradient(135deg,#16213e 0%,#1a2a50 100%);
                            display:flex; align-items:center; gap:.7rem; flex-shrink:0;">
                    <i class="bi bi-stars" style="font-size:1.2rem; color:#c9a84c;"></i>
                    <div style="flex:1;">
                        <div style="font-weight:700; color:#fff; font-size:.9rem;">KontakteDB KI-Assistent</div>
                        <div style="font-size:.7rem; color:rgba(255,255,255,.5);">Firmen · Kontakte · Software-Fragen</div>
                    </div>
                    <button onclick="aiSchliessen()" title="Schließen (Esc)"
                            style="background:none; border:none; color:rgba(255,255,255,.55);
                                   cursor:pointer; font-size:1.4rem; padding:0; line-height:1;">&times;</button>
                </div>

                <div id="aiVerlauf" style="flex:1; overflow-y:auto; padding:1rem 1.2rem;
                                           display:flex; flex-direction:column; gap:.75rem;
                                           min-height:120px; max-height:55vh;">
                </div>

                <div style="padding:.75rem 1.1rem; border-top:1px solid var(--mc-border);
                            background:var(--mc-surface); flex-shrink:0;">
                    <div style="display:flex; gap:.5rem; align-items:center;">
                        <i class="bi bi-stars" style="color:var(--mc-gold); font-size:.9rem; flex-shrink:0;"></i>
                        <input id="aiModalEingabe" type="text"
                               placeholder="Folgefrage stellen… (Enter senden)"
                               style="flex:1; border:1px solid var(--mc-border); border-radius:8px;
                                      padding:.5rem .8rem; font-size:.86rem; background:var(--mc-bg);
                                      color:var(--mc-text); outline:none; font-family:inherit; transition:border-color .2s;"
                               onfocus="this.style.borderColor='var(--mc-gold)'"
                               onblur="this.style.borderColor='var(--mc-border)'"
                               onkeydown="aiModalKeydown(event)" />
                        <button onclick="aiSendenAusModal()"
                                style="background:linear-gradient(135deg,#16213e,#1a3a6e); color:#fff;
                                       border:none; border-radius:8px; padding:.5rem 1rem;
                                       cursor:pointer; font-size:.83rem; font-weight:600;
                                       display:flex; align-items:center; gap:.35rem; flex-shrink:0;">
                            <i class="bi bi-send-fill"></i>
                        </button>
                    </div>
                    <div style="font-size:.68rem; color:var(--mc-text-muted); margin-top:.35rem; padding-left:1.4rem;">
                        Powered by OpenAI · Firmen- und Kontaktdaten werden automatisch einbezogen
                    </div>
                </div>
            </div>
        </div>

        <main class="mc-content">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Warning"] != null)
            {
                <div class="alert alert-warning alert-dismissible fade show mb-4" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Warning"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
                    <i class="bi bi-x-circle-fill me-2"></i>@TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </main>

        <footer class="mc-footer">
            <span>&copy; @DateTime.Now.Year Merkur Privatbank KGaA – Kontaktdatenbank</span>
            <span class="ms-3 text-muted small">Vertraulich</span>
        </footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/kontakte.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <script>
        // ── Topbar-Suche: Modus wählen ───────────────────────────────────
        function topbarSetMode(mode) {
            document.getElementById('topbarMode').value = mode;
            var input = document.getElementById('topbarSearchInput');
            var submit = document.getElementById('topbarSubmit');
            var locked = document.getElementById('topbarLocked');
            var bar = document.getElementById('topbarSearchBar');

            locked.style.display = 'none';
            input.disabled = false;
            submit.disabled = false;
            bar.classList.remove('locked');

            document.querySelectorAll('.topbar-pick-btn').forEach(function(b) {
                b.classList.remove('picked');
            });

            if (mode === 'ai') {
                input.placeholder = 'KI-Suche: z.B. Wer arbeitet bei Siemens?';
                bar.classList.add('mode-ai');
                bar.classList.remove('mode-smart');
                document.querySelector('.topbar-pick-ai').classList.add('picked');
            } else {
                input.placeholder = 'Smart-Suche: Firma, Name, E-Mail, Telefon ...';
                bar.classList.add('mode-smart');
                bar.classList.remove('mode-ai');
                document.querySelector('.topbar-pick-smart').classList.add('picked');
            }
            input.focus();
        }

        // ── KI-Assistent (Modal bleibt für Folgefragen) ───────────────────
        let aiVerlauf = [];

        function aiOeffnen() {
            const modal = document.getElementById('aiModal');
            modal.style.display = 'flex';
            setTimeout(() => document.getElementById('aiModalEingabe')?.focus(), 80);
        }

        function aiSchliessen() {
            const m = document.getElementById('aiModal');
            if (m) m.style.display = 'none';
        }

        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') aiSchliessen();
        });

        function aiModalKeydown(e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                aiSendenAusModal();
            }
        }

        function aiSendenAusModal() {
            const inp = document.getElementById('aiModalEingabe');
            const frage = inp.value.trim();
            if (!frage) return;
            inp.value = '';
            aiSenden(frage);
        }

        function aiMarkdown(text) {
            return text
                .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
                .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
                .replace(/\*(.+?)\*/g, '<em>$1</em>')
                .replace(/`(.+?)`/g, '<code>$1</code>')
                .replace(/^#{1,3}\s+(.+)$/gm, '<strong>$1</strong>')
                .replace(/^[-*]\s+(.+)$/gm, '<li>$1</li>')
                .replace(/(<li>.*<\/li>\n?)+/g, m => `<ul>${m}</ul>`)
                .replace(/\n\n+/g, '</p><p>')
                .replace(/\n/g, '<br>')
                .replace(/^(?!<)(.+)/, '<p>$1</p>');
        }

        function aiNachrichtAppend(rolle, html) {
            const verlauf = document.getElementById('aiVerlauf');
            const div = document.createElement('div');
            div.className = `ai-msg ai-msg-${rolle}`;
            div.innerHTML = `<div class="ai-msg-bubble">${html}</div>`;
            verlauf.appendChild(div);
            verlauf.scrollTop = verlauf.scrollHeight;
            return div;
        }

        async function aiSenden(frage) {
            if (!frage) return;
            aiNachrichtAppend('user', aiMarkdown(frage));

            const verlaufEl = document.getElementById('aiVerlauf');
            const typing = document.createElement('div');
            typing.className = 'ai-msg ai-msg-assistant';
            typing.innerHTML = '<div class="ai-typing"><div class="ai-typing-dot"></div><div class="ai-typing-dot"></div><div class="ai-typing-dot"></div><span>Wird geladen\u2026</span></div>';
            verlaufEl.appendChild(typing);
            verlaufEl.scrollTop = verlaufEl.scrollHeight;

            try {
                const res = await fetch('/AiAssistent/Fragen', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ frage, verlauf: aiVerlauf })
                });
                const data = await res.json();
                verlaufEl.removeChild(typing);

                if (data.error) {
                    aiNachrichtAppend('assistant',
                        '<span style="color:#e74c3c;"><i class="bi bi-exclamation-triangle"><\/i> ' + data.error + '<\/span>');
                } else {
                    aiVerlauf.push({ rolle: 'user', text: frage });
                    aiVerlauf.push({ rolle: 'assistant', text: data.antwort });
                    if (aiVerlauf.length > 10) aiVerlauf = aiVerlauf.slice(-10);
                    aiNachrichtAppend('assistant', aiMarkdown(data.antwort));
                }
            } catch {
                verlaufEl.removeChild(typing);
                aiNachrichtAppend('assistant',
                    '<span style="color:#e74c3c;">Verbindungsfehler. Bitte versuche es erneut.<\/span>');
            } finally {
                document.getElementById('aiModalEingabe')?.focus();
            }
        }
    </script>
</body>
</html>
