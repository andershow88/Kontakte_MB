@model KontakteDB.ViewModels.CompanyListViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Firmen";
    ViewData["Breadcrumb"] = "<span>Firmen</span>";
}

<div class="mc-page-header">
    <div>
        <h1 class="mc-page-title"><i class="bi bi-buildings me-2"></i>Firmen</h1>
        <p class="mc-page-subtitle">@Model.TotalCount Firmen gefunden</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="ExportCsv" asp-route-q="@Model.SearchTerm" class="btn-mc-ghost">
            <i class="bi bi-download me-1"></i> CSV
        </a>
        <a asp-action="Create" class="btn-mc-primary">
            <i class="bi bi-plus-lg me-1"></i> Neue Firma
        </a>
    </div>
</div>

<!-- Filter-Leiste -->
<form method="get" class="mc-filter-bar mb-3">
    <input type="text" name="q" value="@Model.SearchTerm" class="form-control"
           placeholder="Suche nach Name, Ort, E-Mail …" style="min-width:220px; flex:1;" />

    <select name="city" class="form-select" style="min-width:140px;">
        <option value="">Alle Orte</option>
        @foreach (var c in Model.Cities)
        {
            <option value="@c" selected="@(Model.FilterCity == c)">@c</option>
        }
    </select>

    <select name="country" class="form-select" style="min-width:120px;">
        <option value="">Alle Länder</option>
        @foreach (var c in Model.Countries)
        {
            <option value="@c" selected="@(Model.FilterCountry == c)">@c</option>
        }
    </select>

    <select name="sortBy" class="form-select" style="min-width:160px;">
        <option value="name" selected="@(Model.SortBy == "name" || Model.SortBy == null)">Name A–Z</option>
        <option value="name" selected="@(Model.SortBy == "name" && Model.SortDir == "desc")">Name Z–A</option>
        <option value="city">Ort A–Z</option>
        <option value="updated" selected="@(Model.SortBy == "updated")">Zuletzt geändert</option>
        <option value="created" selected="@(Model.SortBy == "created")">Zuletzt erstellt</option>
    </select>

    <input type="hidden" name="sortDir" value="@(Model.SortDir ?? "asc")" />

    <button type="submit" class="btn-mc-primary">
        <i class="bi bi-funnel me-1"></i> Filtern
    </button>
    @if (!string.IsNullOrWhiteSpace(Model.SearchTerm) || !string.IsNullOrWhiteSpace(Model.FilterCity) || !string.IsNullOrWhiteSpace(Model.FilterCountry))
    {
        <a asp-action="Index" class="btn-mc-ghost">
            <i class="bi bi-x-lg"></i>
        </a>
    }
</form>

<div class="mc-card">
    @if (!Model.Companies.Any())
    {
        <div class="mc-card-body text-center py-5 text-muted">
            <i class="bi bi-buildings fs-2 d-block mb-2 opacity-25"></i>
            Keine Firmen gefunden.
        </div>
    }
    else
    {
        <div class="mc-table-wrapper">
            <table class="mc-table">
                <thead>
                    <tr>
                        <th>Firmenname</th>
                        <th class="d-none d-md-table-cell">Ort</th>
                        <th class="d-none d-lg-table-cell">Telefon / E-Mail</th>
                        <th class="d-none d-sm-table-cell" style="text-align:center;">Kontakte</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var c in Model.Companies)
                {
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                @if (c.IsFavorite)
                                {
                                    <i class="bi bi-star-fill" style="color:var(--mc-gold); font-size:0.8rem;"></i>
                                }
                                <div>
                                    <a asp-action="Details" asp-route-id="@c.Id"
                                       class="fw-semibold text-decoration-none" style="color:var(--mc-text);">
                                        @c.Name
                                    </a>
                                    @if (!string.IsNullOrEmpty(c.Industry))
                                    {
                                        <div class="small text-muted">@c.Industry</div>
                                    }
                                </div>
                            </div>
                        </td>
                        <td class="d-none d-md-table-cell" style="font-size:0.82rem; color:var(--mc-text-muted);">
                            @(string.Join(" · ", new[] { c.ZipCode != null && c.City != null ? $"{c.ZipCode} {c.City}" : c.City, c.Country }.Where(x => !string.IsNullOrWhiteSpace(x))))
                        </td>
                        <td class="d-none d-lg-table-cell" style="font-size:0.82rem;">
                            @if (!string.IsNullOrEmpty(c.Phone))
                            {
                                <a href="tel:@c.Phone" class="text-muted d-block text-decoration-none">
                                    <i class="bi bi-telephone me-1"></i>@c.Phone
                                </a>
                            }
                            @if (!string.IsNullOrEmpty(c.Email))
                            {
                                <!-- mailto: öffnet den lokalen Standard-Mailclient (z. B. Outlook) -->
                                <a href="mailto:@c.Email" class="text-muted d-block text-decoration-none">
                                    <i class="bi bi-envelope me-1"></i>@c.Email
                                </a>
                            }
                        </td>
                        <td class="d-none d-sm-table-cell text-center">
                            <span class="mc-badge badge-secondary">@c.ContactCount</span>
                        </td>
                        <td style="text-align:right; white-space:nowrap;">
                            <a asp-action="Details" asp-route-id="@c.Id" class="btn-mc-ghost" style="padding:0.2rem 0.5rem;">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a asp-action="Edit" asp-route-id="@c.Id" class="btn-mc-ghost" style="padding:0.2rem 0.5rem;">
                                <i class="bi bi-pencil"></i>
                            </a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        @if (Model.TotalPages > 1)
        {
            <div class="mc-card-body d-flex justify-content-between align-items-center" style="border-top:1px solid var(--mc-border);">
                <span class="small text-muted">
                    Seite @Model.Page von @Model.TotalPages (@Model.TotalCount Einträge)
                </span>
                <div class="d-flex gap-1">
                    @if (Model.Page > 1)
                    {
                        <a asp-action="Index" asp-route-q="@Model.SearchTerm" asp-route-city="@Model.FilterCity"
                           asp-route-country="@Model.FilterCountry" asp-route-page="@(Model.Page - 1)"
                           class="btn-mc-ghost" style="padding:0.25rem 0.6rem;">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    }
                    @if (Model.Page < Model.TotalPages)
                    {
                        <a asp-action="Index" asp-route-q="@Model.SearchTerm" asp-route-city="@Model.FilterCity"
                           asp-route-country="@Model.FilterCountry" asp-route-page="@(Model.Page + 1)"
                           class="btn-mc-primary" style="padding:0.25rem 0.6rem;">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    }
                </div>
            </div>
        }
    }
</div>
